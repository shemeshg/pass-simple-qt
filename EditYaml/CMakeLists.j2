include(FetchContent)

FetchContent_Declare(
  yaml-cpp
  GIT_REPOSITORY https://github.com/jbeder/yaml-cpp.git
  #GIT_TAG 0.9.0
)
FetchContent_GetProperties(yaml-cpp)

if(NOT yaml-cpp_POPULATED)
  message(STATUS "Fetching yaml-cpp...")
  FetchContent_Populate(yaml-cpp)
  add_subdirectory(${yaml-cpp_SOURCE_DIR} ${yaml-cpp_BINARY_DIR})
endif()

link_libraries(
    yaml-cpp::yaml-cpp
)

{% if qt6_required %}

find_package(Qt6 REQUIRED COMPONENTS 
{%- for comp in qt6_required %}
{{comp}}
{%- endfor %}
)
link_libraries(
{%- for comp in qt6_required %}
Qt6::{{comp}}
{%- endfor %}
)

{% endif %}

{% for comp in qml_singletons -%}
set_source_files_properties({{comp}} PROPERTIES
    QT_QML_SINGLETON_TYPE TRUE
)
{%- endfor %}

qt6_add_qml_module({{module_name}} 
        URI {{module_name}} 
        VERSION 1.0
        SOURCES
            {% for comp in cpp_sources -%}
            {{comp}} 
            {% endfor %}
        QML_FILES
            {% for comp in qml_glob -%}
            {{ comp.as_posix() }} 
            {% endfor %}
{% if RESOURCES %}
        RESOURCES
            {% for comp in RESOURCES -%}
            {{ comp.as_posix() }} 
            {% endfor %}
{% endif %}            
        )
